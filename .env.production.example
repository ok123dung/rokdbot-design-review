# Production env vars for `npm run build` to bake into the bundle.
# Copy this to .env.production (gitignored) with real values before deploying.
#
# DO NOT use `vercel env pull` or `vercel build` — they create
# .vercel/.env.production.local with EMPTY strings that silently override
# this file via Vite precedence and produce a blank-page deployment.
# See scripts/safe-deploy.sh + memory file for the full safe deploy workflow.

VITE_SUPABASE_URL=https://inondhimzqiguvdhyjng.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_REAL_KEY
